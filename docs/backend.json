
{
  "entities": {
    "UserSession": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserSession",
      "type": "object",
      "description": "Represents a single user's interaction session with the FF Account Assist application.",
      "properties": {
        "id": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "createdAt"]
    },
    "CheckoutClick": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "CheckoutClick",
      "type": "object",
      "description": "Registra quando um usuário clica para ir para o checkout (PushinPay).",
      "properties": {
        "id": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "source": { "type": "string", "description": "De onde veio o clique (ex: chat, recuperar, oferta-recusada)" },
        "url": { "type": "string", "description": "URL do checkout clicado" }
      },
      "required": ["id", "timestamp"]
    },
    "Purchase": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Purchase",
      "type": "object",
      "description": "Representa uma compra confirmada via webhook.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string" },
        "status": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "status", "timestamp"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/visits/{visitId}",
        "definition": {
          "entityName": "Visit",
          "schema": { "type": "object" },
          "description": "Registra visitas ao site."
        }
      },
      {
        "path": "/checkoutClicks/{clickId}",
        "definition": {
          "entityName": "CheckoutClick",
          "schema": { "$ref": "#/backend/entities/CheckoutClick" },
          "description": "Registra cada clique em botões de checkout."
        }
      },
      {
        "path": "/purchases/{purchaseId}",
        "definition": {
          "entityName": "Purchase",
          "schema": { "$ref": "#/backend/entities/Purchase" },
          "description": "Compras confirmadas pelo webhook do PushinPay."
        }
      }
    ]
  }
}
