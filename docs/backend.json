
{
  "entities": {
    "UserSession": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserSession",
      "type": "object",
      "description": "Represents a single user's interaction session with the FF Account Assist application.",
      "properties": {
        "id": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "createdAt"]
    },
    "CheckoutClick": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "CheckoutClick",
      "type": "object",
      "description": "Registra quando um usuário clica para ir para o checkout.",
      "properties": {
        "id": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "source": { "type": "string", "description": "De onde veio o clique" },
        "url": { "type": "string", "description": "URL do checkout clicado" }
      },
      "required": ["id", "timestamp"]
    },
    "Purchase": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Purchase",
      "type": "object",
      "description": "Representa uma compra confirmada via webhook.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string" },
        "status": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "accessed": { "type": "boolean", "description": "Se o cliente já acessou a página de entrega." }
      },
      "required": ["id", "status", "timestamp"]
    },
    "AppConfig": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "AppConfig",
      "type": "object",
      "description": "Configurações globais do site editáveis pelo admin.",
      "properties": {
        "siteName": { "type": "string" },
        "primaryColor": { "type": "string", "description": "Cor primária em HSL" },
        "ctaTextColor": { "type": "string", "enum": ["black", "white"], "description": "Cor do texto nos botões principais" },
        "checkoutUrlPt": { "type": "string" },
        "checkoutUrlEnEs": { "type": "string" },
        "headerAvatar": { "type": "string" },
        "teamAvatar": { "type": "string" },
        "ctaText": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/visits/{visitId}",
        "definition": {
          "entityName": "Visit",
          "schema": { "type": "object" },
          "description": "Registra visitas ao site."
        }
      },
      {
        "path": "/checkoutClicks/{clickId}",
        "definition": {
          "entityName": "CheckoutClick",
          "schema": { "$ref": "#/backend/entities/CheckoutClick" },
          "description": "Registra cada clique em botões de checkout."
        }
      },
      {
        "path": "/purchases/{purchaseId}",
        "definition": {
          "entityName": "Purchase",
          "schema": { "$ref": "#/backend/entities/Purchase" },
          "description": "Compras confirmadas pelo webhook."
        }
      },
      {
        "path": "/config/global",
        "definition": {
          "entityName": "AppConfig",
          "schema": { "$ref": "#/backend/entities/AppConfig" },
          "description": "Documento único de configurações do app."
        }
      }
    ]
  }
}
